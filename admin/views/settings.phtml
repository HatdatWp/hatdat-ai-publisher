);

$credit_data = null;
$credit_error = null;

if (!empty($cost_settings['api_key'])) {
    $client = new AI_Publisher_OpenAI_Client($cost_settings['api_key']);
    $credit_data = $client->get_credit_balance();

    if (is_wp_error($credit_data)) {
        $credit_error = $credit_data->get_error_message();
        $credit_data = null;
    }
}
